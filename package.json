{
  "name": "discord-claude-bot",
  "version": "1.0.0",
  "description": "A collaborative Discord bot powered by Claude. Reads and writes to your project repo, pushes to GitHub, searches the web, and connects to Google Drive.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "smoke": "node scripts/smoke.mjs"
  },
  "keywords": [
    "discord",
    "claude",
    "anthropic",
    "bot",
    "ai",
    "collaboration"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215",
    "@anthropic-ai/sdk": "^0.112.3",
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "opusscript": "^0.0.8",
    "sharp": "^0.33.5",
    "simple-git": "^3.27.0",
    "zod": "^4.4.3"
  }
}
