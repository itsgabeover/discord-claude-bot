# ── Discord ──────────────────────────────────────────────────────────────────
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Restrict the bot to specific channels (optional).
# Comma-separated Discord channel IDs. Leave blank to allow all channels.
# ALLOWED_CHANNEL_IDS=123456789,987654321

# ── Anthropic ────────────────────────────────────────────────────────────────
# Get this from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Path to the bot's system prompt / persona.
# Defaults to ./system-prompt.md — copy system-prompt.example.md to that path
# and fill it in. Cached at startup, so restart the bot after editing.
SYSTEM_PROMPT_PATH=./system-prompt.md

# ── GitHub Repo (the codebase the bot works on) ──────────────────────────────
# HTTPS URL of the repo (no token — token goes in GITHUB_TOKEN below)
GITHUB_REPO_URL=https://github.com/yourusername/your-repo

# Identity the bot's commits are authored as. GIT_AUTHOR_EMAIL is REQUIRED —
# the bot refuses to start without it rather than committing as someone else.
# It must be a verified email on a real GitHub account: some hosts reject
# deployments whose commit author can't be matched to one (Vercel does), so a
# made-up address like bot@example.com will fail there. The display name is
# free-form.
GIT_AUTHOR_NAME=Claude Bot
GIT_AUTHOR_EMAIL=you@example.com

# GitHub Personal Access Token with "Contents" read+write permission.
# Create one at https://github.com/settings/tokens?type=beta
# The bot uses this to clone and push to the repo from Render.
GITHUB_TOKEN=ghp_yourpersonalaccesstokenhere

# Where the bot stores its local clone of the repo.
# On Render this will be a temp directory that resets on redeploy —
# that's fine, the bot re-clones on each startup.
REPO_PATH=./repo

# ── Multiple projects (optional) ─────────────────────────────────────────────
# To serve different projects in different Discord servers from one process,
# copy projects.example.json to projects.json — see the README. Everything below
# then acts as the fallback for settings a project doesn't override.
# PROJECTS_CONFIG_PATH=./projects.json
# REPO_ROOT=./repos

# ── Tool packs ───────────────────────────────────────────────────────────────
# Tools are grouped into packs; leave this unset to load all of them.
# Set a comma-separated list to load only what your project needs:
#
#   files    read/write files in the repo
#   git      status, commit, push, pull, log
#   npm      whitelisted npm commands (Node/JS projects)
#   web      web search (needs BRAVE_SEARCH_API_KEY)
#   media    resize/convert images, cut out backgrounds
#   gdrive   read and write a shared Google Drive folder
#   todo     file work for later (needs TODO_DOC_ID and the gdrive pack)
#   discord  send messages to other channels
#   voice    speak in a voice channel (needs ELEVENLABS_API_KEY)
#
# Trimming irrelevant packs mainly improves tool-choice accuracy — the model
# picks better from a focused set. Example for a non-JS project with no Drive:
# ENABLED_TOOL_PACKS=files,git,web
ENABLED_TOOL_PACKS=

# ── Google Drive ─────────────────────────────────────────────────────────────
# Path to your Google service account credentials JSON file.
# On Render, paste the JSON contents into a Secret File (see README).
GOOGLE_CREDENTIALS_PATH=./google-credentials.json

# The ID of the Google Drive folder to use.
# From the URL: drive.google.com/drive/folders/THIS_PART
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Google Doc the `todo` pack appends deferred tasks to.
# Both of these are optional: by default add_todo finds a Doc in the Drive folder
# whose name contains "todo", so creating one is all the setup needed. Set
# TODO_DOC_NAME to match a different name, or TODO_DOC_ID to pin an exact doc —
# worth doing once you have several docs with "todo" in the name, since an
# ambiguous match makes add_todo stop and ask rather than guess.
TODO_DOC_ID=
TODO_DOC_NAME=todo

# ── Web Search ───────────────────────────────────────────────────────────────
# Brave Search API key for web search. Free tier: 2000 searches/month.
# Get one at https://brave.com/search/api/
# Leave blank to disable web search.
BRAVE_SEARCH_API_KEY=

# ── Voice (ElevenLabs TTS) ────────────────────────────────────────────────────
# When the user who @mentions the bot is in a voice channel, the bot can join
# and speak responses out loud using ElevenLabs text-to-speech.
#
# Get your API key at https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# The voice ID to use. Go to Voices in ElevenLabs, pick a voice, click it —
# the ID is in the URL or the "Use" panel. Free tier includes several voices.
# You can also clone a voice from a short audio sample.
ELEVENLABS_VOICE_ID=

# TTS model — defaults to eleven_flash_v2_5 (low latency, good fit for
# speaking live in a Discord voice channel). Other options: eleven_v3,
# eleven_multilingual_v2. Older models like eleven_monolingual_v1 are
# deprecated and will error.
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# ── Webhooks ─────────────────────────────────────────────────────────────────
# Discord channel ID where GitHub and Vercel notifications are posted.
# Right-click a channel in Discord → Copy Channel ID (enable Developer Mode first:
# User Settings → Advanced → Developer Mode).
NOTIFICATIONS_CHANNEL_ID=

# GitHub webhook secret — set the same value here and in GitHub's webhook settings.
# Go to your repo → Settings → Webhooks → Add webhook → Secret.
# Leave blank to skip signature verification (not recommended for production).
GITHUB_WEBHOOK_SECRET=

# Vercel webhook token — optional. If set, Vercel must send this as a Bearer token
# in the Authorization header. Configure it in Vercel → Project → Settings → Webhooks.
VERCEL_WEBHOOK_TOKEN=

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# Max messages to keep in memory per channel
MAX_HISTORY=20

# Safety caps for a single reply's agentic tool-use loop. Hitting either one
# stops the loop and has Claude summarize progress + suggest follow-up
# prompts, instead of silently running forever.
MAX_TOOL_CALLS=30
MAX_TOKENS_PER_TURN=150000
